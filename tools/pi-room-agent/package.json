{
  "name": "pi-room-agent",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Headless iroh-room worker: polls a room tail, detects room-task blocks, claims tasks, and drives Pi over RPC.",
  "engines": {
    "node": ">=20.19"
  },
