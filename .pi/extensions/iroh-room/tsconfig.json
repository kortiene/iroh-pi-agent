{
	// Typecheck-only config (noEmit): at runtime pi loads this extension raw
	// via jiti and aliases @earendil-works/* and typebox to its bundled
	// packages. For portable local/CI typechecking, those packages are installed
	// as devDependencies and resolved from node_modules.
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022"],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"types": ["node"],
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"noEmit": true,
		"allowImportingTsExtensions": true
	},
	"include": ["index.ts", "src/**/*.ts"]
}
